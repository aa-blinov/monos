FROM node:20-alpine

WORKDIR /app

# Copy all frontend files
COPY . .

# Install dependencies with legacy peer deps
RUN npm install --legacy-peer-deps

# Expose Vite dev server port
EXPOSE 5173

# Run Vite dev server with host 0.0.0.0
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5173"]
